<?xml version="1.0" encoding="utf-8"?>
<!--
  Multi Voice Studio の MSIX マニフェスト。
  Identity（Name / Publisher）は Microsoft Partner Center の Product Identity の値に一致させること。
  PyInstaller の onedir 出力（MultiVoiceStudio.exe ＋ _internal/）を full-trust デスクトップアプリとして包む。
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <!-- Version ? version.txt ??????build_msix.ps1 ???????????? -->
  <Identity
    Name="9B6C9F60.MultiVoiceStudio"
    Publisher="CN=E5A55C73-7E5B-4BF9-B37E-C562F23A3A5E"
    Version="1.0.1.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Multi Voice Studio</DisplayName>
    <PublisherDisplayName>Hiroyura</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="ja-JP" />
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="MultiVoiceStudio" Executable="MultiVoiceStudio.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Multi Voice Studio"
        Description="AIによる多言語テキスト読み上げ（TTS）デスクトップアプリ"
        BackgroundColor="#1F6AA5"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
